@using MudBlazor
@rendermode InteractiveServer
@inject IDialogService DialogService

<div class="chat-launcher-container">
    <div class="chat-hint @(showHint ? "visible" : "fade-out")">
        <span>Click here to chat with David Turner...</span>
        <button class="close-hint" @onclick="HideHint">×</button>
    </div>
    <MudFab Class="@($"chat-toggle {(_chatReference != null ? "chat-active" : "")}")"
            Color="Color.Primary"
            StartIcon="@(_chatReference == null ? Icons.Material.Filled.Chat : Icons.Material.Filled.Close)"
            OnClick="ToggleChatWindow" />
</div>

@code {
    private IDialogReference? _chatReference;

    @code {
        private bool showHint = true;

        protected override async Task OnInitializedAsync()
        {
            // Automatically hide the hint after 8 seconds if the user hasn't clicked it
            await Task.Delay(8000);
            await HideHint();
        }

        private async Task HideHint()
        {
            showHint = false;
            StateHasChanged();
        }
    }

    private async Task ToggleChatWindow()
    {
        showHint = false;

        if (_chatReference != null)
        {
            // Close the existing window
            _chatReference.Close();
            _chatReference = null;
        }
        else
        {
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = false,
                FullScreen = false,
                Position = DialogPosition.BottomRight,
                BackdropClick = false,
                CloseButton = true,
                CloseOnEscapeKey = true,
                CloseOnNavigation = false
            };

            // Capture the reference when opening
            _chatReference = await DialogService.ShowAsync<ChatDialog>("David Turner's AI Assistant", options);

            // Listen for when the dialog is closed via its OWN close button
            var result = await _chatReference.Result;
            _chatReference = null; // Reset reference so icon flips back
            StateHasChanged();
        }
    }
}