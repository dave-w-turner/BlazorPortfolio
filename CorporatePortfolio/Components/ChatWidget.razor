@using MudBlazor
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDialogService DialogService
@implements IDisposable
@inject AppState State

<div class="chat-launcher-container">
    <div class="chat-hint @(showHint ? "fade-in-up" : "fade-out")">
        <span>Click here to chat with David Turner...</span>
        <button class="close-hint" @onclick="HideHint">×</button>
    </div>
    @if (State.IsIndexLoaded)
    {
        <MudFab Class="@($"chat-toggle {(_chatReference != null ? "chat-active" : "")} fade-in")"
                Color="Color.Primary"
                StartIcon="@(_chatReference == null ? Icons.Material.Filled.Chat : Icons.Material.Filled.Close)"
                OnClick="ToggleChatWindow" />
    }
</div>

@code {
    private IDialogReference? _chatReference;
    private bool showHint = true;

    protected override async Task OnInitializedAsync()
    {
        State.IndexLoaded += Show;

        if (State.IsIndexLoaded)
        {
            Show();
        }

        await Task.Delay(8000);
        await HideHint();
    }

    private async Task HideHint()
    {
        showHint = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleChatWindow()
    {
        showHint = false;

        if (_chatReference != null)
        {
            _chatReference.Close();
            _chatReference = null;
        }
        else
        {
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = false,
                FullScreen = false,
                Position = DialogPosition.BottomRight,
                BackdropClick = false,
                CloseButton = true,
                CloseOnEscapeKey = true,
                CloseOnNavigation = false,
                BackgroundClass = "chat-no-overlay"
            };

            // CORRECTED CONFIGURATION: Use a dictionary parameter mapping layer
            var parameters = new DialogParameters
            {
                { "Class", "chat-dark" }
            };

            // 1. Pass the parameter dictionary straight to the runtime factory engine
            _chatReference = await DialogService.ShowAsync<ChatDialog>("David Turner's AI Assistant", parameters, options);

            // 2. Offload the close tracking path to the async background monitor thread loop
            _ = HandleDialogCloseAsync(_chatReference);
        }
    }

    private async Task HandleDialogCloseAsync(IDialogReference dialogRef)
    {
        // Await the modal conclusion in the background
        await dialogRef.Result;

        // Safely check if the reference hasn't been changed by an explicit close toggle tap
        if (_chatReference == dialogRef)
        {
            _chatReference = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Show()
    {
        State.IsIndexLoaded = true;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        State.IndexLoaded -= Show;
    }
}
