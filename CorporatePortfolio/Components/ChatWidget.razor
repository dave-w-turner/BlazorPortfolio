@using MudBlazor
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable
@inject AppState State
@inject IJSRuntime JS
@inject IDialogService DialogService

<div class="chat-launcher-container" style="display: flex; flex-direction: column; align-items: flex-end; gap: 8px;">

    <div class="chat-hint @(showHint ? "fade-in-up" : "fade-out")"
         @onclick="HideHint"
         style="cursor: pointer; z-index: 9999 !important; margin: 0; @(!showHint ? "display: none !important;" : "")">

        <div style="display: flex; align-items: center; justify-content: space-between; width: 100%; pointer-events: none;">
            <span>Click here to chat with David Turner...</span>
            <button class="close-hint" @onclick="HideHint" style="pointer-events: auto; background: none; border: none; margin-left: 8px;">×</button>
        </div>
    </div>

    @if (State.AreSkillsLoaded)
    {
        <MudFab Class="@($"chat-toggle {(_chatReference != null ? "chat-active" : "")} fade-in")"
                Color="Color.Primary"
                StartIcon="@(_chatReference == null ? Icons.Material.Filled.Chat : Icons.Material.Filled.Close)"
                OnClick="ToggleChatWindow"
                style="z-index: 9998 !important;" />
    }
</div>

@code {
    private IDialogReference? _chatReference;
    private bool showHint = false;
    private CancellationTokenSource? _cts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            State.SkillsLoaded += Show;

            if (State.AreSkillsLoaded)
            {
                Show();
            }

            var hasSeenHint = await JS.InvokeAsync<string>("localStorage.getItem", "hasSeenChatHint");

            if (hasSeenHint != "true")
            {
                showHint = true;
                await InvokeAsync(StateHasChanged);

                _cts = new CancellationTokenSource();
                _ = StartBackgroundHintTimerAsync(_cts.Token);
            }
        }
    }

    private async Task StartBackgroundHintTimerAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(8000, token);
            if (!token.IsCancellationRequested)
            {
                await HideHint();
            }
        }
        catch (TaskCanceledException) { }
    }

    private async Task HideHint()
    {
        _cts?.Cancel();

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "hasSeenChatHint", "true");
        }
        catch { }

        await InvokeAsync(() =>
        {
            showHint = false;
            StateHasChanged();
        });
    }

    private async Task ToggleChatWindow()
    {
        await HideHint();

        if (_chatReference != null)
        {
            _chatReference.Close();
            _chatReference = null;
        }
        else
        {
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = false,
                FullScreen = false,
                Position = DialogPosition.BottomRight,
                BackdropClick = false,
                CloseButton = true,
                CloseOnEscapeKey = true,
                CloseOnNavigation = false,
                BackgroundClass = "chat-no-overlay"
            };

            var parameters = new DialogParameters
            {
                { "Class", "chat-dark" }
            };

            _chatReference = await DialogService.ShowAsync<ChatDialog>("David Turner's AI Assistant", parameters, options);
            _ = HandleDialogCloseAsync(_chatReference);
        }
    }

    private async Task HandleDialogCloseAsync(IDialogReference dialogRef)
    {
        await dialogRef.Result;

        if (_chatReference == dialogRef)
        {
            _chatReference = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Show()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        State.SkillsLoaded -= Show;
    }
}