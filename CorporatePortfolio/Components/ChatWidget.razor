@using MudBlazor
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDialogService DialogService
@implements IDisposable
@inject AppState State

<div class="chat-launcher-container">
    <div class="chat-hint @(showHint ? "fade-in-up" : "fade-out")">
        <span>Click here to chat with David Turner...</span>
        <button class="close-hint" @onclick="HideHint">×</button>
    </div>
    @if (State.IsIndexLoaded)
    {
        <MudFab Class="@($"chat-toggle {(_chatReference != null ? "chat-active" : "")} fade-in")"
                Color="Color.Primary"
                StartIcon="@(_chatReference == null ? Icons.Material.Filled.Chat : Icons.Material.Filled.Close)"
                OnClick="ToggleChatWindow" />
    }
</div>

@code {
    private IDialogReference? _chatReference;
    private bool showHint = true;

    protected override async Task OnInitializedAsync()
    {
        State.IndexLoaded += Show;

        if (State.IsIndexLoaded)
        {
            Show();
        }

        // Automatically hide the hint after 8 seconds if the user hasn't clicked it
        await Task.Delay(8000);
        await HideHint();        
    }

    private async Task HideHint()
    {
        showHint = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleChatWindow()
    {
        showHint = false;

        if (_chatReference != null)
        {
            _chatReference.Close();
            _chatReference = null;
        }
        else
        {
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = false,
                FullScreen = false,
                Position = DialogPosition.BottomRight,
                BackdropClick = false,
                CloseButton = true,
                CloseOnEscapeKey = true,
                CloseOnNavigation = false
            };

            _chatReference = await DialogService.ShowAsync<ChatDialog>("David Turner's AI Assistant", options);
            var result = await _chatReference.Result;
            _chatReference = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Show()
    {
        State.IsIndexLoaded = true;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        State.IndexLoaded -= Show;
    }
}