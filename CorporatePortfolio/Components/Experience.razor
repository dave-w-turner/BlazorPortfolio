@using CorporatePortfolio.Services
@using CorporatePortfolio.Services.DTO

<div class="section fade-up" id="experience">
    <h2>Experience Highlights</h2>

    <div class="timeline">
        @foreach (var experience in resumeService.GetExperience().Result)
        {
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="customcard">
                    <h3><i data-lucide="briefcase"></i> @experience.Title - @experience.CompanyName (@experience.Date)</h3>

                    @foreach(var detail in experience.Details)
                    {
                        <p>@detail</p>
                    }                    
                </div>
            </div>
        }
    </div>
</div>
