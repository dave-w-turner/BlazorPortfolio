@using CorporatePortfolio.Services
@using CorporatePortfolio.Services.DTO
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppState State
@inject IJSRuntime JS

<div class="section" id="experience">
    <h2>Experience Highlights</h2>

    @if (!_isLoaded)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="timeline">
            @foreach (var experience in State.Experiences)
            {
                var idx = State.Experiences.IndexOf(experience);
                @* Use a unique ID based on the experience object *@
                <div id="@($"exp-{idx}")"
                     class="timeline-item @(State.Experiences.IndexOf(experience) == 0 ? "fade-in" : "fade-up")"
                     style="transition-delay: 0.2s;">
                    <div class="timeline-dot">@experience.Date</div>
                    <div class="customcard">
                        <h3><i class="bi bi-briefcase"></i> @experience.Title - @experience.CompanyName</h3>
                        @foreach (var detail in experience.DetailsFormatted)
                        {
                            <p>@detail</p>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _isLoaded = false;
    private string? _pendingScrollElementId;

    protected override async Task OnInitializedAsync()
    {
        State.ExperiencesOnChange += HandleStateChange;
        State.OnSkillSelected += PrepareScroll;
                       
        if (State.Experiences == null || !State.Experiences.Any())
        {
            await State.InitializeAsync();
        }
        else
        {
            _isLoaded = true;
        }
    }

    private async void PrepareScroll(string skillName)
    {
        // Look at the RAW Details to find the match, not the HTML-formatted ones
        var target = State.Experiences.FirstOrDefault(e =>
            e.Details.Any(d => d.Contains(skillName, StringComparison.OrdinalIgnoreCase)));

        if (target != null)
        {
            int index = State.Experiences.IndexOf(target);
            var targetId = $"exp-{index}";

            await InvokeAsync(async () =>
            {
                await JS.InvokeVoidAsync("scrollToElement", targetId);
            });
        }
    }

    private void HandleStateChange()
    {
        _isLoaded = true;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        State.ExperiencesOnChange -= HandleStateChange;
        State.OnSkillSelected -= PrepareScroll;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initScrollAnimations");
        }

        // Execute scroll only AFTER a render has happened and we have a target
        if (!string.IsNullOrEmpty(_pendingScrollElementId))
        {
            var id = _pendingScrollElementId;
            _pendingScrollElementId = null; // Clear it so it doesn't loop
            await JS.InvokeVoidAsync("scrollToElement", id);
        }
    }
}