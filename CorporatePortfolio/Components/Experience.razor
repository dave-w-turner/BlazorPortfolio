@using CorporatePortfolio.Services
@using CorporatePortfolio.Services.DTO

<div class="section" id="experience">
    <h2>Experience Highlights</h2>

    <div class="timeline">
        @foreach (var experience in experiences)
        {
            <div class="timeline-item @(experiences.IndexOf(experience) == 0 ? "fade-in" : "fade-up")">
                <div class="timeline-dot">@experience.Date</div>
                <div class="customcard">
                    <h3><i data-lucide="briefcase"></i> @experience.Title - @experience.CompanyName</h3>

                    @foreach(var detail in experience.Details)
                    {
                        <p>@detail</p>
                    }                    
                </div>
            </div>
        }
    </div>
</div>

@code {
    List<ExperienceData> experiences = [];

    private async Task LoadExperience()
    {
        experiences = await resumeService.GetExperience();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadExperience();
    }
}