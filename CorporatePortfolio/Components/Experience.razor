@using CorporatePortfolio.Services
@using CorporatePortfolio.Services.DTO
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AppState State
@inject IJSRuntime JS

<div class="section" id="experience">
    <h2>Experience Highlights</h2>

    @if (!_isLoaded)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="timeline">
            @foreach (var experience in State.Experiences)
            {
                <div class="timeline-item @(State.Experiences.IndexOf(experience) == 0 ? "fade-in" : "fade-up ")" style="transition-delay: 0.2s;">
                    <div class="timeline-dot">@experience.Date</div>
                    <div class="customcard">
                        <h3><i data-lucide="briefcase"></i> @experience.Title - @experience.CompanyName</h3>

                        @foreach (var detail in experience.DetailsFormatted)
                        {
                            <p>@detail</p>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _isLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        // If data is missing, fetch it right here
        if (State.Experiences == null || !State.Experiences.Any())
        {
            await State.InitializeAsync();
        }
        
        _isLoaded = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initScrollAnimations");
        }
    }
}