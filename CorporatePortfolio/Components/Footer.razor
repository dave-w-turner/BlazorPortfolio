<div id="built-with" class="section fade-up" style="transition-delay: 0.2s; text-align: center;">

    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 15px; margin-bottom: 5px;">

        <!-- Dynamic CSS Masking Box: Isolates and centers only the pinwheel graphic -->
        <div style="overflow: hidden !important; position: relative !important; display: block !important;" class="rad-logo">
            <img src="images/rad-logo-transparent.png" alt="R.A.D. Icon"
                 class="rad-logo" />
        </div>

        <!-- Company Name Typography Block -->
        <div style="text-align: center; line-height: 1.15; margin-top: -50px;">
            <span style="font-size: 1.1rem; color: #94a3b8; letter-spacing: 0.5px; font-weight: 500;">
                Software Development & IT Services Inc.
            </span>
        </div>
    </div>

    <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 20px;">
        Architected in <b style="color: #7DD3FC;">Visual Studio 2026</b> using a modern AI-first stack.
    </p>

    <div class="tech-grid">
        <div class="tech-card">
            <img src="images/Visual_Studio_Icon_2026.svg" alt="Visual Studio 2026" />
            <span>VS 2026</span>
        </div>
        <div class="tech-card">
            <img src="images/net10ltslogo.svg" alt=".NET 10" />
            <span>.NET 10</span>
        </div>
        <div class="tech-card">
            <img src="images/blazor.svg" alt="Blazor" />
            <span>Blazor</span>
        </div>
        <div class="tech-card">
            <img src="images/llama3_2.svg" alt="Llama 3.2" />
            <span>Llama 3.2</span>
        </div>
        <div class="tech-card">
            <img src="images/groqlogo.svg" alt="Groq" />
            <span>Groq</span>
        </div>
        <div class="tech-card">
            <img src="images/azuredevopslogo.svg" alt="Azure DevOps" />
            <span>Azure DevOps</span>
        </div>
    </div>
</div>

@inject IJSRuntime JS

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(300); // 300ms delay
            await JS.InvokeVoidAsync("initScrollAnimations");
        }
    }
}
