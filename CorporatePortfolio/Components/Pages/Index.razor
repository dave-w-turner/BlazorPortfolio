@page "/"
@inject IJSRuntime JSRuntime
@using CorporatePortfolio.Services

<Header />
<Skills />
<Experience />
<Projects />
<LetsConnect />
<Footer />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Safely initialize animations through a re-callable system window function
            await JSRuntime.InvokeVoidAsync("initScrollAnimations");
        }
    }
}
