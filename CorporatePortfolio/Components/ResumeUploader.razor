@using System.Net.Http
@using Microsoft.AspNetCore.Components.Forms
@inject AntiforgeryStateProvider AntiforgeryProvider
@inject HttpClient Http

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") mb-3 py-2 small text-center"
         role="alert"
         style="max-height: 250px; overflow-y: auto; white-space: pre-wrap; word-break: break-word; font-family: monospace; text-align: left !important;">
        @statusMessage
    </div>
}

<div class="w-100 m-0 p-0">
    <label class="btn btn-auth btn-microsoft d-flex align-items-center cursor-pointer m-0 w-100 @(isUploading ? "disabled" : "")" style="cursor: pointer;">
        
        <InputFile OnChange="HandleFileSelection" accept=".docx" style="display: none;" disabled="@isUploading" />
        
        <span class="auth-icon-wrapper">
            @if (isUploading)
            {
                <span class="spinner-border spinner-border-sm text-white" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-upload"></i>
            }
        </span>
        <span class="auth-text flex-grow-1">@(isUploading ? "Uploading..." : "Upload Resume")</span>
        <span class="auth-spacer"></span>
    </label>
</div>

@code {
    [Parameter] public EventCallback OnUploadSuccess { get; set; }

    private bool isUploading = false;
    private string statusMessage = string.Empty;
    private bool isError = false;
    private const long maxAllowedSize = 1024 * 1024 * 5; // 5MB Limit

    private async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        var selectedFile = e.File;
        if (selectedFile == null) return;

        if (!selectedFile.Name.EndsWith(".docx", StringComparison.OrdinalIgnoreCase))
        {
            SetStatus("Invalid file type. Only .docx files are permitted.", true);
            return;
        }

        if (selectedFile.Size > maxAllowedSize)
        {
            SetStatus("File size exceeds the 5MB maximum limit.", true);
            return;
        }

        try
        {
            isUploading = true;
            SetStatus("Uploading file...", false);
            StateHasChanged();

            var antiforgeryToken = AntiforgeryProvider.GetAntiforgeryToken();

            using var content = new MultipartFormDataContent();
            var fileStream = selectedFile.OpenReadStream(maxAllowedSize);
            var streamContent = new StreamContent(fileStream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/vnd.openxmlformats-officedocument.wordprocessingml.document");
            content.Add(streamContent, "file", selectedFile.Name);

            using var request = new HttpRequestMessage(HttpMethod.Post, "FileUpload/upload-resume");
            request.Content = content;

            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                SetStatus("Resume uploaded successfully!", false);
                StateHasChanged();
                await Task.Delay(600);
                statusMessage = string.Empty; 
                await OnUploadSuccess.InvokeAsync();
            }
            else
            {
                var errorResponse = await response.Content.ReadAsStringAsync();
                SetStatus(!string.IsNullOrEmpty(errorResponse) ? errorResponse : "Upload failed.", true);
            }
        }
        catch (Exception ex)
        {
            SetStatus($"An error occurred: {ex.Message}", true);
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private void SetStatus(string message, bool error)
    {
        statusMessage = message;
        isError = error;
    }
}
