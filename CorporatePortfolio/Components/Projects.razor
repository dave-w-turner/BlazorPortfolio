@using CorporatePortfolio.Services
@using CorporatePortfolio.Services.DTO
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IJSRuntime JS

<div class="section" id="projects">
    <h2>Projects</h2>
    @if (!_isLoaded)
    {
        <p>Loading projects...</p>
    }
    else
    {
        <div class="project-list">
            @foreach (var project in projects)
            {
                <div class="fade-up" style="transition-delay: 0.2s; width: 100%;">
                    <div class="customcard project-wide">
                        <div class="project-header">
                            <h3>@project.Title</h3>
                    
                            <!-- Updated: Stacked Date and Button -->
                            <div class="project-meta-stack">
                                <span class="date">@project.Date</span>
                                @if (!string.IsNullOrEmpty(project.SourceUrl))
                                {
                                    <a href="@project.SourceUrl" target="_blank" class="view-source">
                                        <i data-lucide="github"></i> View Source
                                    </a>
                                }
                            </div>
                        </div>

                        <div class="project-body">
                            <ul>
                                @foreach (var detail in project.DetailsFormatted)
                                {
                                    <li>@detail</li>
                                }
                            </ul>
                        </div>

                        <div class="project-tags">
                            @foreach (var tag in project.Tags)
                            {
                                <span>@tag</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ProjectData> projects = new();
    private bool _isLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        projects = await resumeService.GetProjects();
        
        foreach (var project in projects)
        {
            for (int i = 0; i < project.Details.Count; i++)
            {
                project.DetailsFormatted.Add(await ChatbotService.FormatMessage(project.Details[i]));
            }
        }
        
        _isLoaded = true; // Set to true after all data is ready
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isLoaded) // Wait until data is actually there
        {
            await JS.InvokeVoidAsync("initScrollAnimations");
        }
    }
}