<body>
    <Routes />
    <script src="https://unpkg.com/@@lottiefiles/dotlottie-wc@latest/dist/dotlottie-wc.js" type="module"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
    <script src="_content/Blazor.Bootstrap/blazor.bootstrap.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script>
        window.initChatDrag = (dotNetHelper) => {
            const dialog = document.querySelector('.mud-dialog.chat-dark');
            const header = document.querySelector('.mud-dialog-title');
            if (!dialog || !header) return;

            // 1. BOUNDARY RESET ON RESIZE
            function handleResize() {
                if (!dialog) return;

                // Mobile Viewport (600px or less)
                if (window.innerWidth <= 600) {
                    if (header) header.style.cursor = 'default';
                    resetToDefault();
                    return;
                }

                // Desktop Viewport
                if (header) header.style.cursor = 'move';

                // Boundary Check: If the dragged position overflows a smaller window, reset it back
                if (dialog.style.top && dialog.style.top !== 'auto') {
                    const rect = dialog.getBoundingClientRect();
            
                    if (rect.right > window.innerWidth || rect.bottom > window.innerHeight || rect.left < 0 || rect.top < 0) {
                        resetToDefault();

                        // Erase local state dimensions to revert to fallback positioning
                        if (dotNetHelper) {
                            dotNetHelper.invokeMethodAsync('SaveDimensions', 'auto', 'auto', '440px', '540px');
                        }
                    }
                }
            }

            // Helper to clear manual coordinates and fall back to our CSS media queries
            function resetToDefault() {
                dialog.style.removeProperty('top');
                dialog.style.removeProperty('left');
                dialog.style.removeProperty('bottom');
                dialog.style.removeProperty('right');
                dialog.style.removeProperty('width');
                dialog.style.removeProperty('height');
                dialog.style.removeProperty('margin');
                dialog.style.removeProperty('transform');
                dialog.style.removeProperty('position');
            }

            // Attach listener for browser window resizing
            window.removeEventListener('resize', handleResize);
            window.addEventListener('resize', handleResize);
            handleResize(); // Invoke immediately on load

            // 2. DESKTOP DRAGGING MECHANICS
            header.onmousedown = (e) => {
                if (window.innerWidth <= 600) return;

                e = e || window.event;
                e.preventDefault();

                let startX = e.clientX;
                let startY = e.clientY;
                let hasMoved = false;

                document.onmousemove = (moveEvent) => {
                    moveEvent = moveEvent || window.event;
                    moveEvent.preventDefault();

                    // Setup direct fixed tracking only after first move to prevent jumps
                    if (!hasMoved) {
                        const rect = dialog.getBoundingClientRect();

                        dialog.style.setProperty('margin', '0', 'important');
                        dialog.style.setProperty('transform', 'none', 'important');
                        dialog.style.setProperty('position', 'fixed', 'important');
                
                        dialog.style.setProperty('top', rect.top + 'px', 'important');
                        dialog.style.setProperty('left', rect.left + 'px', 'important');

                        dialog.style.setProperty('bottom', 'auto', 'important');
                        dialog.style.setProperty('right', 'auto', 'important');
                        dialog.style.setProperty('z-index', '3500', 'important');

                        hasMoved = true;
                    }

                    const deltaX = startX - moveEvent.clientX;
                    const deltaY = startY - moveEvent.clientY;

                    startX = moveEvent.clientX;
                    startY = moveEvent.clientY;

                    // Compute Top positioning with boundary clamp
                    let newTop = dialog.offsetTop - deltaY;
                    const maxTop = window.innerHeight - 60; // Leaves the header in view at the bottom
                    newTop = Math.max(0, Math.min(newTop, maxTop));

                    // Compute Left positioning with boundary clamp
                    let newLeft = dialog.offsetLeft - deltaX;
                    const maxLeft = window.innerWidth - 60; // Leaves left edge of header in view
                    newLeft = Math.max(0, Math.min(newLeft, maxLeft));

                    dialog.style.setProperty('top', newTop + "px", 'important');
                    dialog.style.setProperty('left', newLeft + "px", 'important');
                };

                document.onmouseup = () => {
                    document.onmouseup = null;
                    document.onmousemove = null;

                    if (hasMoved && dotNetHelper) {
                        dotNetHelper.invokeMethodAsync('SaveDimensions', 
                            dialog.style.top, dialog.style.left, dialog.style.width, dialog.style.height);
                    }
                };
            };
        }

        // Global scrolling helper function
        window.scrollToBottom = (elementId) => {
            const element = document.getElementById(elementId);
            if (element) {
                requestAnimationFrame(() => {
                    element.scrollTop = element.scrollHeight;
                });
            }
        };

        window.initScrollAnimations = () => {
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.1 
            };

            const animateOnScroll = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible'); 
                        observer.unobserve(entry.target); 
                    }
                });
            }, observerOptions);

            const bindTargets = () => {
                document.querySelectorAll('.fade-up:not(.visible)').forEach(el => {
                    animateOnScroll.observe(el);
                });
            };

            bindTargets();
        };

        window.scrollToElement = (elementId) => {
            // Wrap in frame request to ensure Blazor has finished updating the DOM painting
            requestAnimationFrame(() => {
                const element = document.getElementById(elementId);
                if (element) {
                    const yOffset = -100; // Space for fixed navbar header
            
                    // Calculate absolute position down the page safely, bypassing parent constraints
                    let targetY = 0;
                    let currentElement = element;
                    while (currentElement) {
                        targetY += currentElement.offsetTop;
                        currentElement = currentElement.offsetParent;
                    }
            
                    const finalScrollPosition = targetY + yOffset;

                    // Perform the smooth scroll
                    window.scrollTo({
                        top: finalScrollPosition,
                        behavior: 'smooth'
                    });

                    // Highlight animation feedback
                    element.style.transition = "filter 0.5s ease, transform 0.5s ease";
                    element.style.filter = "brightness(1.3) saturate(1.2)";
            
                    setTimeout(() => {
                        element.style.filter = "";
                    }, 1200);
                }
            });
        }; 

        window.startMatrixRain = () => {
            const canvas = document.getElementById('Matrix');
            const context = canvas.getContext('2d');
    
            const targetDivs = document.getElementsByClassName('profile-glow-ring');
            const targetElement = targetDivs[0]; 

            const katakana = 'アァカサタナハマヤャラワガザダバパイィキシチニヒミリヰギジヂビピウゥクスツヌフムユュルグズブヅプエェケセテネヘメレヱゲゼデベペオォコソトノホモヨョロヲゴゾドボポヴッン';
            const latin = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
            const nums = '0123456789';
            const alphabet = katakana + latin + nums;

            const fontSize = 16;
            let columns = 0;
            const rainDrops = [];

            const draw = () => {
                // ==========================================================================
                // ✨ THE 1:1 RESOLUTION LOCK (THE ULTIMATE FIX)
                // Dynamically matches canvas coordinates to your CSS tracking size every frame
                // This removes layout gaps and prevents characters from looking blurry or faint
                // ==========================================================================
                if (targetElement) {
                    const currentWidth = targetElement.offsetWidth || 750;
                    const currentHeight = targetElement.offsetHeight || 140;

                    if (canvas.width !== currentWidth || canvas.height !== currentHeight) {
                        canvas.width = currentWidth;
                        canvas.height = currentHeight;
                
                        // Recalculate columns based on the true expanded screen width
                        columns = Math.floor(canvas.width / fontSize);
                        for (let x = 0; x < columns; x++) {
                            if (rainDrops[x] === undefined) {
                                rainDrops[x] = Math.floor(Math.random() * (canvas.height / fontSize));
                            }
                        }
                    }
                }

                // Base fade background layer configuration
                context.fillStyle = 'rgba(15, 23, 42, 0.05)';
                context.fillRect(0, 0, canvas.width, canvas.height);

                // ==========================================================================
                // 🚀 BRIGHTNESS OPTIMIZATION
                // Increased alpha up to 0.45 to ensure code drops stand out clearly
                // ==========================================================================
                context.fillStyle = 'rgba(125, 211, 252, 0.45)'; 
                context.font = 'bold ' + fontSize + 'px monospace'; // Bold font helps visibility

                for (let i = 0; i < columns; i++) {
                    const text = alphabet.charAt(Math.floor(Math.random() * alphabet.length));
                    context.fillText(text, i * fontSize, rainDrops[i] * fontSize);

                    if (rainDrops[i] * fontSize > canvas.height && Math.random() > 0.975) {
                        rainDrops[i] = 0;
                    }
                    rainDrops[i]++;
                }

                const dataUrl = canvas.toDataURL(); 
                if (targetElement) {
                    targetElement.style.backgroundImage = `url(${dataUrl})`;
                }
            };

            // Run the animation loop
            setInterval(draw, 33);
        };
    </script>
    <script src="https://unpkg.com"></script>
</body>
</html>
