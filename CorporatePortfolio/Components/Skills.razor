@using CorporatePortfolio.Services
@using CorporatePortfolio.Services.DTO
@inject ResumeService resumeService

<div class="section" id="skills">
    <h2>Core Expertise</h2>

    <div class="grid">
        @foreach (var competency in resumeService.GetCompetencies().Result)
        {
            <div class="customcard glow"><i data-lucide="@competency.Icon"></i> @competency.Name</div>
        }
    </div>
</div>
