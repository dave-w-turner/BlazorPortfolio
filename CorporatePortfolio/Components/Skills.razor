@using CorporatePortfolio.Services
@using CorporatePortfolio.Services.DTO
@inject IJSRuntime JS
@inject AppState State
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="section" id="skills">
    <h2>Core Expertise</h2>

    <div class="grid" @onmouseleave="HandleGlobalMouseOut">
        @foreach (var competency in State.Competencies)
        {
            <!-- Keep classes intact but the hover interaction boundary is handled via CSS uniformly -->
            <div class="customcard @(competency.Name == State.ClickedSkillName ? "selected-active" : "")"
                 @onclick="(() => OnSkillClick(competency.Name))"
                 @onmouseover="() => State.SetHoveredSkillSummary(competency.Name)">
                <span class="card-content">
                    <i class="bi bi-@competency.Icon"></i> @competency.Name
                </span>
            </div>
        }
    </div>
</div>

@code {
    // Fired ONLY when the mouse completely leaves the entire row area of buttons
    private void HandleGlobalMouseOut()
    {
        State.ClearHoveredSkillSummary();
    }

    private async Task OnSkillClick(string skillName)
    {
        State.SetClickedSkillSummary(skillName);

        for (int a = 0; a < State.Experiences.Count; a++)
        {
            for (int b = 0; b < State.Experiences[a].DetailsFormatted.Count; b++)
            {
                var formattedText = (await ChatbotService.FormatMessage(State.Experiences[a].Details[b], true, skillName, true));
                State.Experiences[a].DetailsFormatted[b] = formattedText.Text;

                if (!State.Experiences[a].HasKeyword && formattedText.HasKeyword)
                    State.Experiences[a].HasKeyword = formattedText.HasKeyword;
            }
        }

        State.NotifyStateChanged();
        State.SelectSkill(skillName);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(50);
            await JS.InvokeVoidAsync("initScrollAnimations");
        }
    }
}
