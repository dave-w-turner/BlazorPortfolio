@using CorporatePortfolio.DTO
@using CorporatePortfolio.Services
@using CorporatePortfolio.Services.DTO
@using Microsoft.AspNetCore.Components.WebAssembly.Http
@using System.Text.RegularExpressions
@inject NavigationManager NavigationManager
@inject ChatState State
@inject IJSRuntime JSRuntime
@inject IHostEnvironment HostEnvironment
@inject HttpClient Http
@inject ChatbotService chatService

<MudDialog Class="chat-dark" Style="@_customStyle" ContentClass="mudDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Class="mr-3 mb-n1" />
            David Turner
        </MudText>
    </TitleContent>
    <DialogContent>
        <div id="chat-container" style="flex-grow: 1; overflow-y: auto;" class="pa-4">
            @foreach (var msg in _messages)
            {
                @if (msg.IsConnecting)
                {
                    @* Premium system-style connection indicator centered in the window *@
                    <div class="connecting-system-alert connecting-entry">
                        <div class="pulse-glow"></div>
                        <span class="connecting-text-shimmer">Connecting with David Turner...</span>
                    </div>
                }
                else
                {
                    @* Normal message bubble rendering for both bot and user *@
                    <div style="display: flex; flex-direction: @(msg.IsUser ? "row-reverse" : "row");" class="mb-6 gap-3">
                        <MudAvatar Size="Size.Medium" Elevation="2">
                            @if (!string.IsNullOrEmpty(msg.AvatarUrl))
                            {
                                <MudImage Src="@msg.AvatarUrl" />
                            }
                            else
                            {
                                <MudIcon Icon="@(msg.IsUser ? Icons.Material.Filled.Person : Icons.Material.Filled.SmartToy)" />
                            }
                        </MudAvatar>

                        <div style="max-width: 75%; display: flex; flex-direction: column; align-items: @(msg.IsUser ? "flex-end" : "flex-start");">
                            <MudPaper Class="pa-4 message-fade-in" 
                                      Elevation="1"
                                      Style="@(msg.IsUser ?
                                        "background-color: var(--mud-palette-primary); color: white; border-radius: 15px 15px 0 15px;" :
                                        "background-color: #32333d; color: white; border-radius: 15px 15px 15px 0; border: 1px solid rgba(255,255,255,0.1);")">
                    
                                @* Target the newly added bot message while waiting for the server/typewriter loop *@
                                @if (!msg.IsUser && !msg.IsComplete && string.IsNullOrWhiteSpace(msg.Text))
                                {
                                    <div style="display: flex; gap: 4px; align-items: center; justify-content: center; height: 24px; width: 40px;">
                                        <div style="width: 6px; height: 6px; background-color: #FFFFFF !important; border-radius: 50%; animation: bounce 1.4s infinite ease-in-out both;"></div>
                                        <div style="width: 6px; height: 6px; background-color: #FFFFFF !important; border-radius: 50%; animation: bounce 1.4s infinite ease-in-out both; animation-delay: 0.2s;"></div>
                                        <div style="width: 6px; height: 6px; background-color: #FFFFFF !important; border-radius: 50%; animation: bounce 1.4s infinite ease-in-out both; animation-delay: 0.4s;"></div>
                                    </div>
                                }
                                @* Target the streaming state or completed bot message *@
                                else if (!msg.IsUser)
                                {
                                    @* Use a consistent container for all bot text *@
                                    <div style="color: #F8FAFC; line-height: 1.6; font-size: 1.02em; white-space: pre-wrap; word-break: break-word;">
                                        @((MarkupString)chatService.FormatMessage(msg.Text, msg.IsComplete))
                                    </div>
                                }
                                @* User message rendering *@
                                else
                                {
                                    <MudText Typo="Typo.body1" Style="color: inherit; white-space: pre-wrap; font-size: 0.95rem; word-break: break-word;">
                                        @msg.Text
                                    </MudText>
                                }
                            </MudPaper>
                        </div>
                    </div>
                }
            }

            @* The typing indicator displays below the loop ONLY when the AI is processing the first chunk *@
            @if (_isTyping && _messages.LastOrDefault()?.IsUser == true)
            {
                <div style="display: flex; flex-direction: row;" class="mb-6 gap-3">
                    <MudAvatar Size="Size.Medium" Elevation="2">
                        <MudImage Src="@_avatarUrl" />
                    </MudAvatar>
                    <div style="display: flex; flex-direction: column;">
                        @* Apply David's dark message bubble style directly to this container *@
                        <MudPaper Class="pa-4" 
                                  Elevation="1"
                                  Style="background-color: #32333d; color: white; border-radius: 15px 15px 15px 0; border: 1px solid rgba(255,255,255,0.1);">
                            <div class="typing-indicator" style="display: flex; gap: 4px; align-items: center; justify-content: center; height: 24px; width: 40px;">
                                <div style="width: 6px; height: 6px; background-color: #FFFFFF !important; border-radius: 50%; animation: bounce 1.4s infinite ease-in-out both;"></div>
                                <div style="width: 6px; height: 6px; background-color: #FFFFFF !important; border-radius: 50%; animation: bounce 1.4s infinite ease-in-out both; animation-delay: 0.2s;"></div>
                                <div style="width: 6px; height: 6px; background-color: #FFFFFF !important; border-radius: 50%; animation: bounce 1.4s infinite ease-in-out both; animation-delay: 0.4s;"></div>
                            </div>
                        </MudPaper>
                    </div>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <div class="px-4 pb-2" style="width: 100%;">
            <MudTextField @ref="_textField" 
                          @bind-Value="_userInput"
                          OnKeyDown="HandleKeyDown"
                          Placeholder="Ask about my experience, skills, or projects..."
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Send"
                          AdornmentColor="@(_disableInput ? Color.Default : Color.Primary)"
                          OnAdornmentClick="SendMessage"
                          Immediate="true"
                          Disabled="_disableInput" />
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    private MudTextField<string> _textField = default!;

    // Let our global CSS handle ALL positioning and sizes so it never shrinks
    private string _customStyle => State.HasPosition
        ? $"position: fixed; margin: 0; top: {State.Top}; left: {State.Left}; width: {State.Width}; height: {State.Height}; max-width: none; z-index: 3500 !important;"
        : "z-index: 3500 !important;";

    // 2. Chat Variables
    private List<ChatMessage> _messages = new();
    private string _userInput = "";
    private bool _isTyping = false;
    private bool _disableInput = false;
    private const string _avatarUrl = "images/my-profile-pic.jpg";
    private const string _userAvatarUrl = "images/user-profile-pic.png";

    // 3. Lifecycle & Initialization
    protected override async Task OnInitializedAsync()
    {       
        if (!_messages.Any())
        {
            _isTyping = true;
            _disableInput = true;
            StateHasChanged();

            var connectionMessage = new ChatMessage 
            { 
                Text = "Connecting with David Turner...", 
                IsUser = false, 
                UserName = "David", 
                AvatarUrl = _avatarUrl, 
                IsComplete = false,
                IsConnecting = true 
            };
            _messages.Add(connectionMessage);
            StateHasChanged();

            // 1. Connection Delay
            await Task.Delay(4500);

            connectionMessage.IsConnecting = false;
            connectionMessage.Text = ""; 
            _isTyping = false;
            StateHasChanged();

            // 2. Extended pause to give Llama 3.2 time to load on B2as_v2
            await Task.Delay(2500); 

            // 3. Natural token-like streaming
            string[] chunks = new string[] { "How ", "are you ", "today?" };
            var random = new Random();

            foreach (var chunk in chunks)
            {
                connectionMessage.Text += chunk;
                StateHasChanged();

                int randomDelay = random.Next(160, 280);
                await Task.Delay(randomDelay); 
            }

            connectionMessage.IsComplete = true;
            _disableInput = false;
            StateHasChanged();

            await _textField.FocusAsync();
        }
    }

    // Small helper method to check viewport bounds on the fly
    private bool IsMobileViewport()
    {
        // If the saved horizontal coordinate is larger than the screen width, drop explicit positioning
        if (string.IsNullOrEmpty(State.Left)) return false;
        if (int.TryParse(State.Left.Replace("px", ""), out int leftValue))
        {
            return leftValue > 600; // Returns true if the coordinates cannot fit in a mobile screen
        }
        return false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(150);
            var objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("initChatDrag", objRef);
        }
    }

    // 4. Methods
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            // Give Blazor a tiny moment to sync the last keystroke
            await Task.Yield();
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_userInput) || _isTyping) return;

        var userText = _userInput;
        _messages.Add(new ChatMessage { Text = userText, IsUser = true, UserName = "You", AvatarUrl = _userAvatarUrl, IsComplete = true });

        _userInput = "";
        await ScrollToBottom();
        _isTyping = true; // Displays the dots until the first word appears
        _disableInput = true;
        StateHasChanged();
        await ScrollToBottom();

        var aiMsg = new ChatMessage { Text = "", IsUser = false, UserName = "David", AvatarUrl = _avatarUrl, IsComplete = false };

        var chatRequest = new ChatRequest
        {
            Question = userText,
            History = _messages.TakeLast(10).ToList()
        };

        var request = new HttpRequestMessage(HttpMethod.Post, $"{NavigationManager.BaseUri}api/chat")
        {
            Content = JsonContent.Create(chatRequest)
        };

        request.SetBrowserResponseStreamingEnabled(true);
        request.Headers.Accept.Add(new System.Net.Http.Headers.MediaTypeWithQualityHeaderValue("text/event-stream"));

        try
        {
            var response = await Http.SendAsync(request, HttpCompletionOption.ResponseHeadersRead);
            response.EnsureSuccessStatusCode();

            using var stream = await response.Content.ReadAsStreamAsync();
            using var reader = new StreamReader(stream);

            string? line;
            bool firstWordReceived = false;

            while ((line = await reader.ReadLineAsync()) != null)
            {
                if (line.StartsWith("data: "))
                {
                    var chunk = line["data: ".Length..];

                    // Handle initial typing state
                    if (!firstWordReceived)
                    {
                        _isTyping = false;
                        _messages.Add(aiMsg);
                        firstWordReceived = true;
                    }

                    // Check if the chunk is an actual empty line/newline sent by the LLM
                    if (string.IsNullOrEmpty(chunk))
                    {
                        aiMsg.Text += "\n";
                    }
                    else
                    {
                        // FIX: Explicitly normalize escaped or stripped newlines during data streaming
                        string sanitizedChunk = chunk.Replace("\\n", "\n").Replace("\r", "");
                        aiMsg.Text += sanitizedChunk;
                    }


                    StateHasChanged();
                    await ScrollToBottom();
                    await Task.Yield();
                }
            }
        }
        catch (Exception ex)
        {
            aiMsg.Text = "An error occurred while getting a response.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            aiMsg.IsComplete = true;
            _isTyping = false;
            _disableInput = false;
            StateHasChanged();
            await ScrollToBottom();

            await _textField.FocusAsync(); 
        }
    }

    [JSInvokable]
    public void SaveDimensions(string top, string left, string width, string height)
    {
        State.Top = top; State.Left = left; State.Width = width; State.Height = height;
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("scrollToBottom", "chat-container");
    }      
}

<style>
.radar-signal {
    position: relative;
    width: 10px;
    height: 10px;
    background-color: #7DD3FC; /* Sky Blue Accent */
    border-radius: 50%;
    flex-shrink: 0;
}

.radar-signal::before,
.radar-signal::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    border: 2px solid #7DD3FC;
    animation: radarWave 1.8s infinite ease-out;
    opacity: 0;
}

.radar-signal::after {
    animation-delay: 0.9s;
}

@@keyframes radarWave {
    0% {
        width: 10px;
        height: 10px;
        opacity: 0.8;
    }
    100% {
        width: 32px;
        height: 32px;
        opacity: 0;
    }
}

.connecting-text {
    color: #7DD3FC !important;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.3px;
    animation: textFade 1.8s infinite ease-in-out;
}

@@keyframes textFade {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
}

    .chat-dark {
        background-color: #27272f !important;
        color: white !important; /* Force overall text to white */
        z-index: 3000 !important;
    }

        /* 1. Fix Title and Icon Visibility */
        .chat-dark .mud-dialog-title,
        .chat-dark .mud-dialog-title .mud-text,
        .chat-dark .mud-icon-root {
            color: white !important;
        }

        /* 2. Fix Textbox Background and Text Color */
        .chat-dark .mud-input-control {
            background-color: #32333d !important; /* Slightly lighter than window bg */
            border-radius: 4px;
        }

        .chat-dark .mud-input-root {
            color: white !important;
        }

        /* 3. Fix Placeholder Visibility (Very Important) */
        .chat-dark .mud-input-outlined::placeholder,
        .chat-dark .mud-input-outlined::-webkit-input-placeholder {
            color: rgba(255, 255, 255, 0.5) !important;
            opacity: 1 !important;
        }

        /* 4. Fix Input Border Color */
        .chat-dark .mud-input-outlined-border {
            border-color: rgba(255, 255, 255, 0.2) !important;
        }

        /* 5. Fix the Typing Indicator dots */
        .chat-dark .typing-dot {
            width: 8px;
            height: 8px;
            /* Force the dots to be white so they pop against #27272f */
            background-color: #FFFFFF !important;
            border-radius: 50%;
            animation: bounce 1.4s infinite ease-in-out both;
        }

        /* 1. Target the MudPaper containing David's text */
        .mud-paper:not(.user-message) .mud-typography-body1 {
            line-height: 1.6;
        }

        /* 2. Style the bullets */
        /* Note: This logic works best if we use the Regex helper to wrap bullets in a span,
           but for a quick CSS-only 'look better' fix, we can style the text block */
        .mud-paper {
            transition: all 0.2s ease-in-out;
        }

        /* Optional: Add a slight border-left to David's messages to make them pop */
        .mud-paper:not(.user-message) {
            border-left: 4px solid #1E90FF;
        }

    /* This creates a clean "hanging indent" for your list items */
    .mud-typography-body1 {
        display: block;
        text-align: left;
        line-height: 1.6;
    }

    /* Optional: Add a slight glow to David's message bubble */
    .mud-paper:not(.user-message) {
        box-shadow: 0 0 10px rgba(30, 144, 255, 0.1) !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
    }

    /* Fade-in and slight slide-up animation for incoming real text */
    .message-fade-in {
        animation: messageScaleEntry 0.35s cubic-bezier(0.1, 0.9, 0.2, 1);
    }

    @@keyframes messageScaleEntry {
        0% {
            opacity: 0;
            transform: scale(0.94) translateY(4px);
        }
        100% {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .connecting-bubble-container {
        display: flex;
        align-items: center;
        gap: 14px;
        height: 24px;
        white-space: nowrap;
        min-width: 295px;
    }

    /* A modern, high-tech glowing pulse */
    .pulse-glow {
        position: relative;
        width: 8px;
        height: 8px;
        background-color: #38BDF8; /* Vibrant Sky Blue */
        border-radius: 50%;
        flex-shrink: 0;
        box-shadow: 0 0 10px rgba(56, 189, 248, 0.6);
    }

    .pulse-glow::after {
        content: "";
        position: absolute;
        top: -6px;
        left: -6px;
        right: -6px;
        bottom: -6px;
        border-radius: 50%;
        border: 2px solid rgba(56, 189, 248, 0.4);
        animation: glowRing 1.8s infinite ease-out;
    }

    .connecting-system-alert {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 14px;
    
        /* 1. Reduced left margin from 52px to move it further to the left */
        margin: 18px 0 18px 12px; 
        padding: 12px 20px;
    
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.65), rgba(30, 41, 59, 0.45));
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(56, 189, 248, 0.35);
        border-radius: 28px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37),
                    0 0 15px rgba(56, 189, 248, 0.15);
        white-space: nowrap;
        width: fit-content;
    }

    /* Vibrating soft beacon effect */
    .pulse-glow {
        position: relative;
        width: 8px;
        height: 8px;
        background-color: #38BDF8;
        border-radius: 50%;
        flex-shrink: 0;
        box-shadow: 0 0 12px 2px rgba(56, 189, 248, 0.8);
    }

    .pulse-glow::after {
        content: "";
        position: absolute;
        top: -6px;
        left: -6px;
        right: -6px;
        bottom: -6px;
        border-radius: 50%;
        border: 1.5px solid rgba(56, 189, 248, 0.5);
        animation: glowRing 1.8s infinite ease-out;
    }

    @@keyframes glowRing {
        0% { transform: scale(0.6); opacity: 1; }
        100% { transform: scale(2); opacity: 0; }
    }

    /* Beautiful color-shifting text shimmer */
    .connecting-text-shimmer {
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.8px;
        background: linear-gradient(
            110deg, 
            #94A3B8 20%, 
            #38BDF8 40%, 
            #06B6D4 60%, 
            #94A3B8 80%
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shimmerSlide 2s infinite linear;
    }

    @@keyframes shimmerSlide {
        0% { background-position: 100% 0; }
        100% { background-position: -100% 0; }
    }

    /* Smooth fade and slide-up entry for the connecting bubble */
    .connecting-entry {
        animation: connectingFadeInUp 0.45s cubic-bezier(0.1, 0.9, 0.2, 1);
    }

    @@keyframes connectingFadeInUp {
        0% {
            opacity: 0;
            transform: translateY(10px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes bounce {
        0%, 80%, 100% { 
            transform: scale(0);
        } 
        40% { 
            transform: scale(1.0);
        }
    }

    /* Add a blinking cursor to the last message while it is NOT complete */
    .streaming-active::after {
        content: "▋";
        display: inline-block;
        vertical-align: middle;
        animation: blink 1s step-start infinite;
        color: #38BDF8;
        margin-left: 2px;
    }

    @@keyframes blink {
        50% { opacity: 0; }
    }

    .scroll-locked {
        overflow: auto;
    }

/* ===================================================
   DESKTOP VIEW (Screen width > 600px)
   =================================================== */
   @@media (min-width: 601px) {
    /* Target the dialog container explicitly to disable centered flex layouts */
        body .mud-dialog-container .mud-dialog.chat-dark {
            position: fixed !important;
        
            /* 1. Places it exactly where it belongs above the purple toggle button */
            bottom: clamp(100px, 9.5vh, 125px) !important;
            right: 40px !important;
            top: auto !important;
            left: auto !important;
        
            /* 2. Forces balanced, square proportions */
            width: 600px !important;
            height: 540px !important;
            min-width: 440px !important;
            max-width: 600px !important;
            max-height: 72vh !important;
        
            /* 3. Disables centered flexbox alignments */
            transform: none !important;
            margin: 0 !important;
            z-index: 3500 !important;
            border-radius: 12px !important;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5) !important;
        }

        body .mud-dialog-container .mud-dialog.chat-dark #chat-container {
            height: calc(100% - 130px) !important;
            max-height: calc(540px - 135px) !important;
            overflow-y: auto !important;
        }
    }

/* ===================================================
   MOBILE/COMACT VIEW (Screen width > 600px)
   =================================================== */
   @@media (max-width: 600px) {
        body .mud-dialog-container .mud-dialog.chat-dark {
            position: fixed !important;
        
            /* Centered in small viewports to leave room for the header */
            top: 52% !important;
            left: 50% !important;
            transform: translate(-50%, -52%) !important;
            bottom: auto !important;
            right: auto !important;
        
            /* Mobile responsive boundaries */
            width: 92vw !important;
            height: 72vh !important;
            max-width: 440px !important;
            max-height: 560px !important;
        
            margin: 0 !important;
            border-radius: 16px !important;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6) !important;
            z-index: 3500 !important;
        }

        body .mud-dialog-container .mud-dialog.chat-dark #chat-container {
            height: calc(72vh - 125px) !important;
            max-height: calc(72vh - 125px) !important;
            overflow-y: auto !important;
        }
    }

    /* Target the specific class you see in the inspector */
    .chat-dark .mud-input-control.mud-disabled {
        background-color: rgba(0, 0, 0, 0.4) !important; /* Darken the background */
        opacity: 0.6 !important;
        cursor: not-allowed !important;
    }

    /* Dim the text, placeholder, and icon inside the disabled container */
    .chat-dark .mud-disabled input, 
    .chat-dark .mud-disabled .mud-icon-root {
        color: rgba(255, 255, 255, 0.2) !important;
        -webkit-text-fill-color: rgba(255, 255, 255, 0.2) !important;
    }

    /* Hide the border when disabled to make it look 'collapsed' */
    .chat-dark .mud-disabled .mud-input-outlined-border {
        border-color: rgba(255, 255, 255, 0.05) !important;
    }
</style>