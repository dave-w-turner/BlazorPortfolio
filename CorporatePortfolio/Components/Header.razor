@using CorporatePortfolio.Components.Authentication
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IJSRuntime JS

<div class="portfolio-header-actions">
    <CascadingAuthenticationState>
        <AuthorizeView>
            <Authorized>
                <form action="Account/Logout" method="post" class="m-0 p-0">
                    <AntiforgeryToken />
                    <button type="submit" class="btn-dashboard-logout">
                        <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                    </button>
                </form>
            </Authorized>
            <NotAuthorized>
                <button class="btn-dashboard-login" @onclick="() => showLogin = true">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </NotAuthorized>
        </AuthorizeView>
    </CascadingAuthenticationState>
</div>

<ProviderList @bind-IsOpen="showLogin" />

<div class="hero fade-in">
    <div class="hero-content">
        <div class="profile-container-wrapper">
            <canvas id="Matrix" style="position: absolute; top: 0; left: 0; z-index: -1; display:none;"></canvas>
            <div class="profile-glow-ring"></div>
            <img src="@currentHeadShot" class="profile-img" alt="Profile Picture" />
        </div>
        <h1>David Turner</h1>
        <p class="subtitle">Senior Software Developer • Enterprise Systems • Cloud & Automation</p>
    
        <!-- New Resume & Contact Buttons -->
        <div class="hero-buttons fade-in" style="margin-top: 25px; display: flex; justify-content: center; gap: 15px;">
            <a href="DavidTurner_Resume.docx" target="_blank" class="btn-primary" style="padding: 10px 24px; border-radius: 50px;">
                <i class="bi bi-file-earmark-pdf"></i> View Resume
            </a>
            <a href="#connect" class="btn-secondary" style="padding: 10px 24px; border-radius: 50px;">
                Get in Touch
            </a>
        </div>
    </div>
</div>

@code {
    private List<ImageMagick.MagickImage> headShots = [];
    private string? currentHeadShot;
    private bool showLogin = false;

    protected override async Task OnInitializedAsync()
    {
        var headshot_primary = new ImageMagick.MagickImage("wwwroot/images/headshots/headshot_primary.png");
        headShots.Add(headshot_primary);

        foreach (var file in Directory.GetFiles("wwwroot/images/headshots/").Where(f => f.Contains("headshot_alt_")))
        {
            var headshot = new ImageMagick.MagickImage(file);
            headShots.Add(headshot);
        }

        headShots.AddRange(await ImageSplitter.SplitGridImage("wwwroot/images/headshots/headshot_grid_1.png", 3, 4));
        headShots.AddRange(await ImageSplitter.SplitGridImage("wwwroot/images/headshots/headshot_grid_2.png", 4, 3));

        byte[] imageBytes = headShots[Random.Shared.Next(headShots.Count)].ToByteArray(ImageMagick.MagickFormat.Png);

        string base64String = Convert.ToBase64String(imageBytes);
        currentHeadShot = $"data:image/png;base64,{base64String}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("startMatrixRain");
        }
    }
 }